# Neon Postgres connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URI=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/btd?sslmode=require

# Payload secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# URL this CMS is served from
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# URL of the SvelteKit frontend (for CORS)
WEB_URL=http://localhost:5173
