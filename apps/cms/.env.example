# Neon Postgres connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URI=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/btd?sslmode=require

# Payload secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# URL this CMS is served from
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# URL of the SvelteKit frontend (for CORS)
WEB_URL=http://localhost:5173

# EPA ECHO registered email for direct public access (higher rate limits)
# If unset, the scraper falls back to the first Payload admin user's email automatically.
# Register your email at https://echo.epa.gov to enable direct access.
# Without a registered email, anonymous rate limits apply (300 req/hr, 1500/day).
ECHO_EMAIL=
